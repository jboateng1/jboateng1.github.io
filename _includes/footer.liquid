{% comment %}
  LOCAL OVERRIDE of al_folio_core's _includes/footer.liquid.
  Keep in sync with the gem on theme upgrades. The only bespoke additions are the
  visit-counter span in `footer_contents` and the GoatCounter scripts at the end.
{% endcomment %}
{% capture footer_contents %}
  &copy; Copyright {{ site.time | date: '%Y' }}
  {{ site.first_name }}
  {{ site.middle_name }}
  {{ site.last_name }}. {{ site.footer_text }}
  {% if site.impressum_path %}
    <a href="{{ site.url }}{{ site.baseurl }}{{ site.impressum_path }}">Impressum</a>.
  {% endif %}
  {% if site.last_updated %}
    Last updated: {{ 'now' | date: '%B %d, %Y' }}.
  {% endif %}
  &nbsp;&middot;&nbsp;
  <span class="visit-counter" title="Total page views (GoatCounter)" style="color: var(--global-footer-text-color);">
    <i class="fa-solid fa-eye"></i>&nbsp;<span id="visit-count" style="color: inherit; font: inherit;">0</span> visits
  </span>
{% endcapture %}

{% if site.footer_fixed %}
  <footer class="fixed-bottom" role="contentinfo">
    <div class="container mt-0">
      {{ footer_contents }}
    </div>
  </footer>
{% else %}
  <footer class="sticky-bottom mt-5" role="contentinfo">
    {% if site.newsletter.enabled %}
      {% if site.plugins contains 'al_newsletter' %}
        {% include plugins/al_newsletter_form_center.liquid %}
      {% else %}
        {% include newsletter.liquid %}
      {% endif %}
    {% endif %}

    <div class="container">
      {{ footer_contents }}
    </div>
  </footer>
{% endif %}

<!-- GoatCounter: privacy-friendly visit tracking (records the page view). -->
<script
  data-goatcounter="https://jboateng1.goatcounter.com/count"
  async
  src="//gc.zgo.at/count.js"
></script>

<!--
  Fill the footer counter with the site-wide total views. GoatCounter's
  /counter/TOTAL.json is broken (always 0) and the SVG/HTML badges that hold the
  real total don't send CORS headers, so we sum the per-path JSON counters (which
  work and allow CORS) for every page on the site. The path list is generated at
  build time from all pages + the projects collection, so it stays complete as
  pages are added. Pages with no views simply return 0.
  Stays at the default "0" if requests fail or are blocked by a tracker blocker.
-->
<script>
  document.addEventListener('DOMContentLoaded', function () {
    var base = 'https://jboateng1.goatcounter.com/counter/';
    var paths = [
      {%- assign all_urls = site.html_pages | concat: site.projects | map: 'url' | uniq -%}
      {%- for u in all_urls -%}
        {%- if u and u != '' -%}{{ u | jsonify }},{% endif -%}
      {%- endfor -%}
    ];
    Promise.all(
      paths.map(function (p) {
        return fetch(base + encodeURIComponent(p) + '.json')
          .then(function (r) {
            return r.ok ? r.json() : { count: '0' };
          })
          .then(function (d) {
            return parseInt(String(d.count || '0').replace(/,/g, ''), 10) || 0;
          })
          .catch(function () {
            return 0;
          });
      })
    ).then(function (counts) {
      var total = counts.reduce(function (a, b) {
        return a + b;
      }, 0);
      if (total > 0) {
        document.getElementById('visit-count').textContent = total.toLocaleString();
      }
    });
  });
</script>
